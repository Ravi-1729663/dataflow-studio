{
  "id": null,
  "uid": "dataflow-overview",
  "title": "DataFlow Studio - Pipeline Overview",
  "tags": ["dataflow-studio"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline runs by status (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (dataflow_pipeline_runs_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rows processed (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(dataflow_pipeline_rows_processed_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Retries (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(dataflow_pipeline_run_retries_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pipeline runs over time, by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (status) (rate(dataflow_pipeline_runs_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Run duration (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(dataflow_pipeline_run_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(dataflow_pipeline_run_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP requests (Django)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum by (view) (rate(django_http_requests_total_by_view_transport_method_total[5m]))",
          "legendFormat": "{{view}}",
          "refId": "A"
        }
      ]
    }
  ]
}
